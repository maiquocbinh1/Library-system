# --- MySQL source (read-only migration) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=books

# --- MongoDB Atlas (target) ---
# Use SRV connection string from Atlas UI; ensure IP allowlist / user role includes readWrite
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/books?retryWrites=true&w=majority

# Optional: database name override (defaults to path in URI or "books")
# MONGODB_DB_NAME=books

# Set to "true" to log documents without writing (still connects)
# DRY_RUN=false
