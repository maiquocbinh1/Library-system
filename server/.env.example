# Server
PORT=3000

# MongoDB (required)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Auth / Crypto (required)
JWT_SECRET=replace_with_a_long_random_secret
SECRET_CRYPTO=replace_with_a_long_random_crypto_key

# Gmail OAuth2 (optional - for forgot password / notifications)
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=
REFRESH_TOKEN=
USER_EMAIL=
